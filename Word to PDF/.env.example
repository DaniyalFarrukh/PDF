# ──────────────────────────────────────────────
#  Universal Document to PDF Converter — Config
# ──────────────────────────────────────────────

# Server port
PORT=3000

# Path to soffice.exe (LibreOffice headless)
# Default Windows install location:
SOFFICE_PATH=C:\Program Files\LibreOffice\program\soffice.exe

# Maximum upload size in MB
MAX_FILE_SIZE_MB=50

# Auto-delete generated PDFs after this many milliseconds (default: 10 minutes)
# Set to 0 to disable auto-cleanup
OUTPUT_TTL_MS=600000
